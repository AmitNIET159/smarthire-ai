# ============================================
# SmartHire AI - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ---------- Server ----------
NODE_ENV=development
PORT=5000

# ---------- MongoDB ----------
# For Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/smarthire-ai
# For MongoDB Atlas: Use mongodb+srv://<user>:<pass>@cluster.mongodb.net/smarthire-ai
MONGODB_URI=mongodb://localhost:27017/smarthire-ai
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.xxxxx.mongodb.net/smarthire-ai

# ---------- JWT ----------
JWT_SECRET=your-secret-key-here-min-64-characters-for-production
JWT_EXPIRES_IN=7d

# ---------- AI Provider (Multi-Provider Fallback) ----------
# "auto"        — tries Gemini → HuggingFace → OpenRouter in order (recommended)
# "gemini"      — only use Gemini
# "huggingface" — only use HuggingFace
# "openrouter"  — only use OpenRouter
AI_PROVIDER=auto

# Google Gemini (free tier: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# HuggingFace (free tier: https://huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# OpenRouter (free tier: https://openrouter.ai/keys)
OPENROUTER_API_KEY=your-openrouter-api-key

# ---------- CORS ----------
# Comma-separated origins allowed
CLIENT_URL=http://localhost:3000

# ---------- Rate Limiting ----------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
